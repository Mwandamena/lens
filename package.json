{
  "name": "lens",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "storybook": "bun --filter @social-lens/ui storybook",
    "ds:dev": "bun --filter @social-lens/ds storybook",
    "ds:build": "bun --filter @social-lens/ds build-storybook"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "trustedDependencies": [
    "@prisma/engines",
    "prisma"
  ],
  "overrides": {
    "@prisma/engines": {
      "@prisma/debug": "*"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "dependencies": {
    "pino-pretty": "^13.1.3"
  }
}
